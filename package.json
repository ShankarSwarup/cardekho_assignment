{
  "name": "automatch-pro",
  "version": "1.0.0",
  "description": "AutoMatch Pro Enterprise Monorepo",
  "private": true,
  "workspaces": [
    "apps/client",
    "apps/server"
  ],
  "scripts": {
    "dev:server": "npm run dev --workspace=apps/server",
    "dev:client": "npm run dev --workspace=apps/client",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "debug": "npm run debug --workspace=@automatch/server",
    "build": "npm run build --workspace=@automatch/server && npm run build --workspace=@automatch/client",
    "build:watch": "concurrently \"npm run build:watch --workspace=@automatch/server\" \"npm run build:watch --workspace=@automatch/client\"",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "dependencies": {
    "build": "^0.1.4",
    "npm": "^11.18.0",
    "run": "^1.5.0"
  }
}
