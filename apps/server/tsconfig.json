{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",

    "rootDir": "./src",
    "outDir": "./dist",

    "lib": ["ES2022"],

    "strict": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,

    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,

    "declaration": true,
    "sourceMap": true,

    "baseUrl": ".",
    "paths": {
      "@automatch/types": ["../../packages/types/src"],
      "@automatch/utils": ["../../packages/utils/src"]
    }
  },

  "include": ["src/**/*"],

  "exclude": [
    "node_modules",
    "dist",
    "**/*.test.ts"
  ]
}