{
  "name": "@automatch/server",
  "version": "1.0.0",
  "description": "AutoMatch Pro Express Backend API",
  "main": "dist/server.js",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "debug": "node --inspect=0.0.0.0:9229 --import=tsx src/server.ts",
    "build": "tsc",
    "build:watch": "tsc -w",
    "start": "node dist/server.js",
    "seed": "tsx src/utils/seed.ts",
    "test": "mocha --import=tsx src/tests/**/*.test.ts --timeout 10000 --exit"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.2.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.3.1",
    "winston": "^3.13.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/chai": "^5.2.3",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.12.7",
    "@types/supertest": "^7.2.0",
    "chai": "^6.2.2",
    "mocha": "^11.7.6",
    "supertest": "^7.2.2",
    "tsx": "^4.7.2",
    "typescript": "^5.4.5"
  }
}
